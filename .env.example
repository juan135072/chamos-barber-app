# InsForge Configuration (migrated from Supabase, 2026-05-12)
NEXT_PUBLIC_INSFORGE_BASE_URL=https://insforge.chamosbarber.com
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_insforge_anon_jwt

# Server-only admin key (starts with ik_). Used by API routes for admin ops.
INSFORGE_API_KEY=your_insforge_api_key

# OneSignal Push Notifications
# App ID: Público (puede estar en código)
NEXT_PUBLIC_ONESIGNAL_APP_ID=63aa14ec-de8c-46b3-8949-e9fd221f8d70

# Habilitar/Deshabilitar OneSignal (true por defecto)
NEXT_PUBLIC_ONESIGNAL_ENABLED=true

# REST API Key: PRIVADO (solo para backend/edge functions)
# Obtener de: https://app.onesignal.com/apps/YOUR_APP_ID/settings
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key